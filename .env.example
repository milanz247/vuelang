# ── Server ────────────────────────────────────────────────────────────────────
PORT=9090
ENV=development
APP_NAME=Vuelang
APP_URL=http://localhost:9090

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=vuelang
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=25

# ── Auth ──────────────────────────────────────────────────────────────────────
# SECURITY: generate with:  openssl rand -base64 64
JWT_SECRET=change-me-before-deploying-to-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for development ONLY.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:9090

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REQUESTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@vuelang.dev
MAIL_FROM_NAME=Vuelang

# ── Seeds ─────────────────────────────────────────────────────────────────────
# Set to "true" to run seeders on boot (development only)
DB_SEED=false
