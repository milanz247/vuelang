# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# "development" → hot-reload mode (proxy to Vite)
# "production"  → serve embedded ui/dist from single binary
ENV=development

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=go_cloud_erp

# ── Auth ──────────────────────────────────────────────────────────────────────
# SECURITY: generate a strong random secret before going to production.
# Example:  openssl rand -base64 48
JWT_SECRET=change-me-before-deploying-to-production
